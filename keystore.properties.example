# Copy this file to "keystore.properties" (which is gitignored) for local release signing
# in Android Studio. CI uses GitHub Actions secrets instead of this file.
#
# storeFile is resolved relative to the :app module, so "../" points at the repo root.
storeFile=../suvmorse-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=suvmorse
keyPassword=YOUR_KEY_PASSWORD
